generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String             @id @default(cuid())
  name           String?
  email          String?            @unique
  phone          String?            @unique
  emailVerified  DateTime?
  image          String?
  role           String             @default("FREE")
  password       String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  accounts       Account[]
  sessions       Session[]
  resumes        Resume[]
  jobAnalyses    JobAnalysis[]
  applications   Application[]
  interviews     InterviewSession[]
  subscription   Subscription?
  usageTracking  UsageTracking[]
  careerInsights CareerInsight[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  paystackCustomerId String?   @unique
  paystackPlanCode   String?
  paystackSubCode    String?   @unique
  status             String    @default("ACTIVE")
  plan               String    @default("monthly")
  amount             Int?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id            String        @id @default(cuid())
  userId        String
  title         String
  fileName      String?
  fileUrl       String?
  rawText       String?       @db.Text
  parsedData    String?       @db.Text
  atsScore      Int?
  version       Int           @default(1)
  isOptimized   Boolean       @default(false)
  optimizedText String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications  Application[]
  jobAnalyses   JobAnalysis[]
}

model JobAnalysis {
  id                 String        @id @default(cuid())
  userId             String
  resumeId           String?
  jobTitle           String?
  company            String?
  jobDescription     String        @db.Text
  parsedRequirements String?       @db.Text
  requiredSkills     String?       @db.Text
  matchScore         Int?
  missingSkills      String?       @db.Text
  recommendations    String?       @db.Text
  createdAt          DateTime      @default(now())
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume             Resume?       @relation(fields: [resumeId], references: [id])
  applications       Application[]
}

model Application {
  id               String       @id @default(cuid())
  userId           String
  resumeId         String?
  jobAnalysisId    String?
  coverLetter      String?      @db.Text
  emailDraft       String?      @db.Text
  emailStyle       String?
  emailSubject     String?
  status           String       @default("draft")
  coverLetterScore Int?
  emailScore       Int?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume           Resume?      @relation(fields: [resumeId], references: [id])
  jobAnalysis      JobAnalysis? @relation(fields: [jobAnalysisId], references: [id])
}

model InterviewSession {
  id             String    @id @default(cuid())
  userId         String
  jobTitle       String?
  difficulty     String    @default("standard")
  questionType   String    @default("mixed")
  questions      String?   @db.Text
  answers        String?   @db.Text
  feedback       String?   @db.Text
  readinessScore Int?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageTracking {
  id     String   @id @default(cuid())
  userId String
  action String
  count  Int      @default(1)
  date   DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action, date])
}

model CareerInsight {
  id               String   @id @default(cuid())
  userId           String
  missingSkills    String?  @db.Text
  recommendedCerts String?  @db.Text
  experienceGaps   String?  @db.Text
  careerLevel      String?
  marketDemand     String?  @db.Text
  nextLevelNeeds   String?  @db.Text
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}