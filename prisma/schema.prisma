generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String             @id @default(cuid())
  name           String?
  email          String?            @unique
  phone          String?            @unique
  emailVerified  DateTime?
  image          String?
  role           String             @default("FREE")
  password       String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  accounts       Account[]
  sessions       Session[]
  resumes        Resume[]
  jobAnalyses    JobAnalysis[]
  applications   Application[]
  interviews     InterviewSession[]
  recruiterProfile  RecruiterProfile?
  subscription   Subscription?
  usageTracking  UsageTracking[]
  careerInsights CareerInsight[]
  chatConversations ChatConversation[]
  teamMemberships RecruiterTeamMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  paystackCustomerId String?   @unique
  paystackPlanCode   String?
  paystackSubCode    String?   @unique
  status             String    @default("ACTIVE")
  plan               String    @default("monthly")
  amount             Int?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id            String        @id @default(cuid())
  userId        String
  title         String
  fileName      String?
  fileUrl       String?
  rawText       String?       @db.Text
  parsedData    String?       @db.Text
  atsScore      Int?
  version       Int           @default(1)
  isOptimized   Boolean       @default(false)
  optimizedText String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications  Application[]
  jobAnalyses   JobAnalysis[]
}

model JobAnalysis {
  id                 String        @id @default(cuid())
  userId             String
  resumeId           String?
  jobTitle           String?
  company            String?
  jobDescription     String        @db.Text
  parsedRequirements String?       @db.Text
  requiredSkills     String?       @db.Text
  matchScore         Int?
  missingSkills      String?       @db.Text
  recommendations    String?       @db.Text
  createdAt          DateTime      @default(now())
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume             Resume?       @relation(fields: [resumeId], references: [id])
  applications       Application[]
}

model Application {
  id               String       @id @default(cuid())
  userId           String
  resumeId         String?
  jobAnalysisId    String?
  coverLetter      String?      @db.Text
  emailDraft       String?      @db.Text
  emailStyle       String?
  emailSubject     String?
  status           String       @default("draft")
  coverLetterScore Int?
  emailScore       Int?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume           Resume?      @relation(fields: [resumeId], references: [id])
  jobAnalysis      JobAnalysis? @relation(fields: [jobAnalysisId], references: [id])
}

model InterviewSession {
  id             String    @id @default(cuid())
  userId         String
  jobTitle       String?
  difficulty     String    @default("standard")
  questionType   String    @default("mixed")
  questions      String?   @db.Text
  answers        String?   @db.Text
  feedback       String?   @db.Text
  readinessScore Int?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageTracking {
  id     String   @id @default(cuid())
  userId String
  action String
  count  Int      @default(1)
  date   DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action, date])
}

model CareerInsight {
  id               String   @id @default(cuid())
  userId           String
  missingSkills    String?  @db.Text
  recommendedCerts String?  @db.Text
  experienceGaps   String?  @db.Text
  careerLevel      String?
  marketDemand     String?  @db.Text
  nextLevelNeeds   String?  @db.Text
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatConversation {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New Conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

model ChatMessage {
  id             String            @id @default(cuid())
  conversationId String
  role           String
  content        String            @db.Text
  createdAt      DateTime          @default(now())
  conversation   ChatConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model RecruiterProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyToEmail    String?
  companySlug     String?   @unique
  slugLocked      Boolean   @default(false)
  activityLogs    RecruiterActivityLog[]
  teamMembers     RecruiterTeamMember[]
  invites         RecruiterInvite[]
  interviews      RecruiterInterview[]
  interviewSettings RecruiterInterviewSettings?

  // Company Info
  companyName     String
  companySize     String?
  industry        String?
  website         String?
  emailsSent      RecruiterEmail[]
  logo            String?
  description     String?   @db.Text

  // Usage Tracking
  cvsUsedThisMonth Int      @default(0)
  cvsResetDate     DateTime @default(now())

  // Relations
  jobPostings      JobPosting[]
  candidates       RecruiterCandidate[]
  applications     RecruiterApplication[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ── Global Interview Message Template ─────────────────────────────────────────

model RecruiterInterviewSettings {
  id          String           @id @default(cuid())
  recruiterId String           @unique
  recruiter   RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  // Global opening
  globalOpening       String?  @db.Text
  globalOpeningType   MessageType @default(TEXT)
  globalOpeningUrl    String?

  // Global closing
  globalClosing       String?  @db.Text
  globalClosingType   MessageType @default(TEXT)
  globalClosingUrl    String?

  // Global mid-interview instructions (JSON array)
  globalInstructions  String?  @db.Text

  updatedAt   DateTime @updatedAt @default(now())
}

model JobPosting {
  id              String    @id @default(cuid())
  recruiterId     String
  recruiter       RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  interviews      RecruiterInterview[]

  jobSlug         String?
  title           String
  description     String    @db.Text
  requirements    String?   @db.Text
  location        String?
  type            JobType   @default(FULL_TIME)
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String?   @default("NGN")
  deadline        DateTime?
  status          JobStatus @default(DRAFT)

  candidates      RecruiterCandidate[]
  applications    RecruiterApplication[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model RecruiterCandidate {
  id              String    @id @default(cuid())
  recruiterId     String
  recruiter       RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  emails          RecruiterEmail[]
  interviews      RecruiterInterview[]

  jobId           String?
  job             JobPosting? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  fileName        String
  rawText         String    @db.Text

  candidateName   String?
  candidateEmail  String?
  candidatePhone  String?

  aiAnalysis      String?   @db.Text
  atsScore        Int?      @default(0)

  status          CandidateStatus @default(NEW)
  notes           String?   @db.Text

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model RecruiterEmail {
  id              String    @id @default(cuid())
  recruiterId     String
  recruiter       RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  candidateId     String?
  candidate       RecruiterCandidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  type            String
  to              String
  subject         String
  message         String    @db.Text
  replyTo         String?
  ccSelf          Boolean   @default(false)
  hasAttachment   Boolean   @default(false)
  attachmentName  String?

  status          String    @default("sent")
  resendId        String?
  openedAt        DateTime?
  openCount       Int       @default(0)

  createdAt       DateTime  @default(now())
}

model RecruiterApplication {
  id              String    @id @default(cuid())
  recruiterId     String
  recruiter       RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  cvFileUrl       String?
  interviews      RecruiterInterview[]

  jobId           String?
  job             JobPosting? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  candidateName   String
  candidateEmail  String
  candidatePhone  String?
  coverLetter     String?   @db.Text

  cvText          String?   @db.Text
  cvFileName      String?

  aiAnalysis      String?   @db.Text
  atsScore        Int?      @default(0)
  aiSummary       String?   @db.Text

  source          String    @default("form")
  status          ApplicationStatus @default(UNREAD)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ── Phase 4: Activity Log ──────────────────────────────────────────────────────

model RecruiterActivityLog {
  id          String   @id @default(cuid())
  recruiterId String
  recruiter   RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  type        ActivityType
  title       String
  description String?
  meta        String?
  createdAt   DateTime @default(now())

  @@index([recruiterId])
  @@index([createdAt])
}

model RecruiterTeamMember {
  id          String     @id @default(cuid())
  recruiterId String
  recruiter   RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        TeamRole   @default(MEMBER)
  joinedAt    DateTime   @default(now())

  @@unique([recruiterId, userId])
  @@index([recruiterId])
}

model RecruiterInvite {
  id          String       @id @default(cuid())
  recruiterId String
  recruiter   RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  email       String
  role        TeamRole     @default(MEMBER)
  token       String       @unique @default(cuid())
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())
  acceptedAt  DateTime?

  @@index([recruiterId])
  @@index([token])
}

// ── Phase 5: Interviews ────────────────────────────────────────────────────────

model RecruiterInterview {
  id                    String            @id @default(cuid())
  recruiterId           String
  recruiter             RecruiterProfile  @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  candidateId           String?
  candidate             RecruiterCandidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  applicationId         String?
  application           RecruiterApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  jobId                 String?
  job                   JobPosting?       @relation(fields: [jobId], references: [id], onDelete: SetNull)

  interviewType         InterviewType     @default(TEXT)
  mode                  InterviewMode     @default(ASYNC)
  status                InterviewStatus   @default(PENDING)

  // Live takeover
  isLive                Boolean           @default(false)
  liveStartedAt         DateTime?
  liveMessage           String?           @db.Text // recruiter types → AI reads

  candidateName         String
  candidateEmail        String?
  candidateLocation     String?
  jobTitle              String?
  cvSummary             String?           @db.Text

  // Per-interview custom messages
  openingMessage        String?           @db.Text
  openingMessageType    MessageType       @default(TEXT)
  openingMessageUrl     String?

  closingMessage        String?           @db.Text
  closingMessageType    MessageType       @default(TEXT)
  closingMessageUrl     String?

  // Mid-interview instructions (JSON array of {trigger, type, timing, message})
  customInstructions    String?           @db.Text

  // Recording
  recordingUrl          String?           // Supabase Storage path
  recordingUploadedAt   DateTime?

  shareToken            String            @unique @default(cuid())

  scheduledAt           DateTime?
  startedAt             DateTime?
  completedAt           DateTime?

  summary               String?           @db.Text
  finalScore            Int?
  finalRecommendation   String?

  totalQuestions        Int               @default(0)
  answeredQuestions     Int               @default(0)

  questions             RecruiterInterviewQuestion[]

  createdAt             DateTime          @default(now())

  @@index([recruiterId])
  @@index([candidateId])
  @@index([shareToken])
  @@index([status])
}

model RecruiterInterviewQuestion {
  id              String              @id @default(cuid())
  interviewId     String
  interview       RecruiterInterview  @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  question        String              @db.Text
  questionType    QuestionType        @default(BEHAVIOURAL)
  order           Int

  candidateAnswer String?             @db.Text
  aiScore         Int?
  aiFeedback      String?             @db.Text
  skipped         Boolean             @default(false)

  answeredAt      DateTime?
  createdAt       DateTime            @default(now())

  @@index([interviewId])
  @@index([order])
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  REMOTE
  HYBRID
}

enum JobStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

enum CandidateStatus {
  NEW
  REVIEWED
  SHORTLISTED
  REJECTED
  HIRED
}

enum ApplicationStatus {
  UNREAD
  READ
  SHORTLISTED
  REJECTED
  HIRED
}

enum ActivityType {
  CV_UPLOADED
  CV_BULK_UPLOADED
  JOB_CREATED
  JOB_UPDATED
  JOB_CLOSED
  APPLICATION_RECEIVED
  CANDIDATE_STATUS_CHANGED
  EMAIL_SENT
  BULK_EMAIL_SENT
  TEAM_MEMBER_INVITED
  TEAM_MEMBER_JOINED
  TEAM_MEMBER_REMOVED
  SETTINGS_UPDATED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum InterviewStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InterviewMode {
  ASYNC
  LIVE
}

enum InterviewType {
  TEXT
  VOICE
  VIDEO
}

enum MessageType {
  TEXT
  AUDIO
  VIDEO
}

enum QuestionType {
  CV_VERIFICATION
  LOCATION_BASED
  JOB_SPECIFIC
  BEHAVIOURAL
}
