generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String             @id @default(cuid())
  name           String?
  email          String?            @unique
  phone          String?            @unique
  emailVerified  DateTime?
  image          String?
  role           String             @default("FREE")
  password       String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  accounts       Account[]
  sessions       Session[]
  resumes        Resume[]
  jobAnalyses    JobAnalysis[]
  applications   Application[]
  interviews     InterviewSession[]
  recruiterProfile  RecruiterProfile?
  subscription   Subscription?
  usageTracking  UsageTracking[]
  careerInsights CareerInsight[]
  chatConversations ChatConversation[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  paystackCustomerId String?   @unique
  paystackPlanCode   String?
  paystackSubCode    String?   @unique
  status             String    @default("ACTIVE")
  plan               String    @default("monthly")
  amount             Int?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id            String        @id @default(cuid())
  userId        String
  title         String
  fileName      String?
  fileUrl       String?
  rawText       String?       @db.Text
  parsedData    String?       @db.Text
  atsScore      Int?
  version       Int           @default(1)
  isOptimized   Boolean       @default(false)
  optimizedText String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications  Application[]
  jobAnalyses   JobAnalysis[]
}

model JobAnalysis {
  id                 String        @id @default(cuid())
  userId             String
  resumeId           String?
  jobTitle           String?
  company            String?
  jobDescription     String        @db.Text
  parsedRequirements String?       @db.Text
  requiredSkills     String?       @db.Text
  matchScore         Int?
  missingSkills      String?       @db.Text
  recommendations    String?       @db.Text
  createdAt          DateTime      @default(now())
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume             Resume?       @relation(fields: [resumeId], references: [id])
  applications       Application[]
}

model Application {
  id               String       @id @default(cuid())
  userId           String
  resumeId         String?
  jobAnalysisId    String?
  coverLetter      String?      @db.Text
  emailDraft       String?      @db.Text
  emailStyle       String?
  emailSubject     String?
  status           String       @default("draft")
  coverLetterScore Int?
  emailScore       Int?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume           Resume?      @relation(fields: [resumeId], references: [id])
  jobAnalysis      JobAnalysis? @relation(fields: [jobAnalysisId], references: [id])
}

model InterviewSession {
  id             String    @id @default(cuid())
  userId         String
  jobTitle       String?
  difficulty     String    @default("standard")
  questionType   String    @default("mixed")
  questions      String?   @db.Text
  answers        String?   @db.Text
  feedback       String?   @db.Text
  readinessScore Int?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageTracking {
  id     String   @id @default(cuid())
  userId String
  action String
  count  Int      @default(1)
  date   DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action, date])
}

model CareerInsight {
  id               String   @id @default(cuid())
  userId           String
  missingSkills    String?  @db.Text
  recommendedCerts String?  @db.Text
  experienceGaps   String?  @db.Text
  careerLevel      String?
  marketDemand     String?  @db.Text
  nextLevelNeeds   String?  @db.Text
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatConversation {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New Conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

model ChatMessage {
  id             String            @id @default(cuid())
  conversationId String
  role           String
  content        String            @db.Text
  createdAt      DateTime          @default(now())
  conversation   ChatConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model RecruiterProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyToEmail    String? 
   companySlug     String?   @unique   
  slugLocked      Boolean   @default(false) 

  // Company Info
  companyName     String
  companySize     String?   // "1-10", "11-50", "51-200", "201-500", "500+"
  industry        String?
  website         String?
  emailsSent      RecruiterEmail[]
  logo            String?
  description     String?   @db.Text

  // Usage Tracking (resets monthly)
  cvsUsedThisMonth Int      @default(0)
  cvsResetDate     DateTime @default(now())

  // Relations
  jobPostings      JobPosting[]
  candidates       RecruiterCandidate[]
  applications     RecruiterApplication[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model JobPosting {
  id              String    @id @default(cuid())
  recruiterId     String
  recruiter       RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  // Job Details
  jobSlug         String?
  title           String
  description     String    @db.Text
  requirements    String?   @db.Text
  location        String?
  type            JobType   @default(FULL_TIME)
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String?   @default("NGN")
  deadline        DateTime?

  // Status
  status          JobStatus @default(DRAFT)

  // Relations
  candidates      RecruiterCandidate[]
  applications    RecruiterApplication[]  

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model RecruiterCandidate {
  id              String    @id @default(cuid())
  recruiterId     String
  recruiter       RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  emails          RecruiterEmail[]

  // Optional link to a specific job
  jobId           String?
  job             JobPosting? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // CV Info
  fileName        String
  rawText         String    @db.Text

  // Extracted by AI
  candidateName   String?
  candidateEmail  String?
  candidatePhone  String?

  // AI Analysis (stored as JSON string)
  aiAnalysis      String?   @db.Text
  atsScore        Int?      @default(0)

  // Workflow Status
  status          CandidateStatus @default(NEW)
  notes           String?   @db.Text

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ── Enums ─────────────────────────────────────────────
enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  REMOTE
  HYBRID
}

enum JobStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

enum CandidateStatus {
  NEW
  REVIEWED
  SHORTLISTED
  REJECTED
  HIRED
}

model RecruiterEmail {
  id              String    @id @default(cuid())
  recruiterId     String
  recruiter       RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  // Candidate link
  candidateId     String?
  candidate       RecruiterCandidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  // Email details
  type            String    // interview_invite, rejection, offer, followup, waitlist
  to              String
  subject         String
  message         String    @db.Text
  replyTo         String?
  ccSelf          Boolean   @default(false)
  hasAttachment   Boolean   @default(false)
  attachmentName  String?

  // Status
  status          String    @default("sent") // sent, failed
  resendId        String?   // Resend message ID for tracking
  openedAt        DateTime?
  openCount       Int        @default(0)

  createdAt       DateTime  @default(now())
}

model RecruiterApplication {
  id              String    @id @default(cuid())
  recruiterId     String
  recruiter       RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  cvFileUrl       String?

  // Which job they applied for
  jobId           String?
  job             JobPosting? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // Candidate info (from form)
  candidateName   String
  candidateEmail  String
  candidatePhone  String?
  coverLetter     String?   @db.Text

  // CV
  cvText          String?   @db.Text
  cvFileName      String?

  // AI Analysis
  aiAnalysis      String?   @db.Text
  atsScore        Int?      @default(0)
  aiSummary       String?   @db.Text

  // Source
  source          String    @default("form") // "form" | "email"

  // Status
  status          ApplicationStatus @default(UNREAD)

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum ApplicationStatus {
  UNREAD
  READ
  SHORTLISTED
  REJECTED
  HIRED
}